# Copy this file to .env.local and fill real values.
# Never commit .env.local.

# Supabase serverless REST
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Brickset API (server fallback if browser headers are not sent)
BRICKSET_API_KEY=your_brickset_api_key
BRICKSET_USER_HASH=your_brickset_user_hash

# Optional Brickset base URL
BRICKSET_API_BASE_URL=https://brickset.com/api/v3.asmx
